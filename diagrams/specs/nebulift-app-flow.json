    },
    {
      "from": "cv",
      "to": "decision",
      "tone": "cyan",
      "label": "",
      "fromSide": "right",
      "toSide": "left",
      "bend": 0
    },
    {
      "from": "decision",
      "to": "manifest",
      "tone": "cyan",
      "label": "",
      "fromSide": "right",
      "toSide": "left",
      "bend": 0
    },
    {
      "from": "manifest",
      "to": "review",
      "tone": "cyan",
      "label": "",
      "fromSide": "bottom",
      "toSide": "top",
      "bend": 0
    },
    {
      "from": "review",
      "to": "training",
      "tone": "violet",
      "label": "",
      "fromSide": "left",
      "toSide": "right",
      "bend": 0
    },
    {
      "from": "training",
      "to": "registry",
      "tone": "violet",
      "label": "",
      "fromSide": "left",
      "toSide": "right",
      "bend": 0
    },
    {
      "from": "registry",
      "to": "cv",
      "tone": "violet",
      "label": "",
      "fromSide": "top",
      "toSide": "bottom",
      "bend": -40
    }
