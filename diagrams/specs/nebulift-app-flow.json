{
  "id": "nebulift-app-flow",
  "title": "Nebulift App Flow",
  "subtitle": "Local FITS triage, review, retraining, and local model promotion.",
  "width": 1800,
  "height": 980,
  "legend": [
    {
      "label": "Primary local workflow",
      "tone": "cyan"
    },
    {
      "label": "Feedback and retraining loop",
      "tone": "violet"
    }
  ],
  "nodes": [
    {
      "id": "ingest",
      "kind": "card",
      "x": 60,
      "y": 200,
      "w": 340,
      "h": 220,
      "tone": "cyan",
      "icon": "telescope",
      "eyebrow": "1. Ingest",
      "titleLines": [
        "Raw FITS Session"
      ],
      "bodyLines": [
        "Observing runs arrive as .fits, .fit, or .fts.",
        "Nebulift sorts from source, originals intact."
      ],
      "badges": [
        "CLI",
        "Local disk"
      ]
    },
    {
      "id": "cv",
      "kind": "card",
      "x": 460,
      "y": 200,
      "w": 360,
      "h": 220,
      "tone": "mint",
      "icon": "python",
      "eyebrow": "2. Analyze",
      "titleLines": [
        "CV Artifact Detector"
      ],
      "bodyLines": [
        "Loads FITS, normalizes frames, and flags streaks,",
        "clouds, saturation, hot pixels, and quality."
      ],
      "badges": [
        "Python",
        "Astropy"
      ]
    },
    {
      "id": "decision",
      "kind": "card",
      "x": 880,
      "y": 200,
      "w": 380,
      "h": 220,
      "tone": "violet",
      "icon": "brain-circuit",
      "eyebrow": "3. Decide",
      "titleLines": [
        "Thresholds + Optional ML"
      ],
      "bodyLines": [
        "CV thresholds assign clean,",
        "review, or contaminated labels.",
        "Promoted models can take over."
      ],
      "badges": [
        "ResNet18",
        "Promoted defaults"
      ]
    },
    {
      "id": "manifest",
      "kind": "card",
      "x": 1320,
      "y": 200,
      "w": 360,
      "h": 220,
      "tone": "slate",
      "icon": "file-json",
      "eyebrow": "4. Record",
      "titleLines": [
        "Manifest + Buckets"
      ],
      "bodyLines": [
        "Each batch writes artifact evidence,",
        "CV labels, review flags,",
        "and move destinations."
      ],
      "badges": [
        "JSON",
        "report / move"
      ]
    },
    {
      "id": "review",
      "kind": "card",
      "x": 1320,
      "y": 560,
      "w": 360,
      "h": 220,
      "tone": "amber",
      "icon": "terminal",
      "eyebrow": "5. Review",
      "titleLines": [
        "Human Corrections",
        "and Evaluation"
      ],
      "bodyLines": [
        "Terminal review writes label fixes to manifest.",
        "Calibration and evaluation turn reviewed sessions",
        "into sharper thresholds and clearer calls."
      ],
      "badges": []
    },
    {
      "id": "training",
      "kind": "card",
      "x": 880,
      "y": 560,
      "w": 380,
      "h": 220,
      "tone": "pink",
      "icon": "chart-line",
      "eyebrow": "6. Train",
      "titleLines": [
        "Curated Dataset to",
        "Model Training"
      ],
      "bodyLines": [
        "Export class folders, train from FITS,",
        "or turn reviewed manifests into checkpoints."
      ],
      "badges": []
    },
    {
      "id": "registry",
      "kind": "card",
      "x": 460,
      "y": 560,
      "w": 360,
      "h": 220,
      "tone": "violet",
      "icon": "database",
      "eyebrow": "7. Promote",
      "titleLines": [
        "Registry + Local Settings"
      ],
      "bodyLines": [
        "Model metadata, calibration, and thresholds stay",
        "in local JSON for trusted later defaults."
      ],
      "badges": [
        "model_registry.json"
      ]
    }
  ],
  "edges": [
    {
